@page
@model IndexModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<h3>@ViewData["Title"]</h3>
<partial name="_StatusMessage" for="StatusMessage" />
<div class="row ManageProfile">
    <div class="col-md-6">
        <form id="profile-form" method="post">
            <div class="profile-div">
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                <div class="mb-3">
                    <div style="float: left; width: 40%; margin-right: 20px;">
                        <label asp-for="Input.Firstname">Förnamn: *</label>
                        <input asp-for="Input.Firstname" class="form-control" aria-required="true" placeholder="Ditt förnamn" />
                        <span asp-validation-for="Input.Firstname" class="text-danger"></span>
                    </div>
                    <div style="float: left; width:55%;">
                        <label asp-for="Input.Lastname">Efternamn: *</label>
                        <input asp-for="Input.Lastname" class="form-control" aria-required="true" placeholder="Ditt efternamn" />
                        <span asp-validation-for="Input.Lastname" class="text-danger"></span>
                    </div>
                </div>
                <div style="width: 100%; height: 20px; clear: both;"></div>
                <div class="mb-3">
                    <label asp-for="Username">Användarnamn (Epost) *</label>
                    <input asp-for="Username" class="form-control" placeholder="Please choose your username." disabled />
                    
                </div>
                <div class="mb-3">
                    <label asp-for="Input.PhoneNumber">Telefonnr:</label>
                    <input asp-for="Input.PhoneNumber" class="form-control" placeholder="Ange ditt telefonnr."/>                    
                    <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                </div>
            
                <div><strong>Fakturaadress:</strong></div>
                <div class="mb-3">
                    <label asp-for="Input.InvoiceName">Namn: *</label>
                    <input asp-for="Input.InvoiceName" class="form-control" aria-required="true" placeholder="Ditt namn" />
                    <span asp-validation-for="Input.InvoiceName" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Input.InvoiceStreetAddress">Gatuadress: *</label>
                    <input asp-for="Input.InvoiceStreetAddress" class="form-control" aria-required="true" placeholder="Din gatuadress" />
                    <span asp-validation-for="Input.InvoiceStreetAddress" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <div style="float: left; width: 29%; margin-right: 20px;">
                        <label asp-for="Input.InvoiceZipcode">Postnr: *</label>
                        <input asp-for="Input.InvoiceZipcode" class="form-control" aria-required="true" placeholder="Ditt postnr" />
                        <span asp-validation-for="Input.InvoiceZipcode" class="text-danger"></span>
                    </div>
                    <div style="float: left; width:66%;">
                        <label asp-for="Input.InvoiceCity">Ort: *</label>
                        <input asp-for="Input.InvoiceCity" class="form-control" aria-required="true" placeholder="Din ort" />
                        <span asp-validation-for="Input.InvoiceCity" class="text-danger"></span>
                    </div>
                </div>

                <div style="width: 100%; height: 20px; clear: both;"></div>

                <div style="margin-top: 25px;"><strong>Leveransadress:</strong></div>
                <div class="mb-3">
                    <label asp-for="Input.DeliveryName">Namn</label>
                    <input asp-for="Input.DeliveryName" class="form-control" aria-required="false" placeholder="Ditt namn" />
                    <span asp-validation-for="Input.DeliveryName" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Input.DeliveryStreetAddress">Gatuadress</label>
                    <input asp-for="Input.DeliveryStreetAddress" class="form-control" aria-required="false" placeholder="Din gatuadress" />
                    <span asp-validation-for="Input.DeliveryStreetAddress" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <div style="float: left; width: 29%; margin-right: 20px;">
                        <label asp-for="Input.DeliveryZipcode">Postnr</label>
                        <input asp-for="Input.DeliveryZipcode" class="form-control" aria-required="false" placeholder="Ditt postnr" />
                        <span asp-validation-for="Input.DeliveryZipcode" class="text-danger"></span>
                    </div>
                    <div style="float: left; width: 66%;">
                        <label asp-for="Input.DeliveryCity">Ort</label>
                        <input asp-for="Input.DeliveryCity" class="form-control" aria-required="false" placeholder="Din ort" />
                        <span asp-validation-for="Input.DeliveryCity" class="text-danger"></span>
                    </div>
                </div>
                <div style="width: 100%; height: 20px; clear: both;"></div>
            </div>
 
            <button id="update-profile-button" type="submit" class="w-100 btn btn-lg btn-primary">Spara</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
