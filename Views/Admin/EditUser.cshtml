
@model LexiElectronics.Models.ApplicationUser

@{
    ViewData["Title"] = "Edit user";
}

<partial name="adminMenuPartial" />
<div class="adminPage">
    @if (User.Identity?.IsAuthenticated == true && (User.IsInRole("AdminManager")))
    {
       
        <h3 class="adminHeader">Ändra användare</h3>
   
        <div class="col-md-6">
            <form id="profile-form" asp-action="SaveEditedUser"method="post">
                <div class="profile-div">
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                    <input asp-for="Id" type="hidden" />
                 
                    <div class="mb-3">
                        <label asp-for="UserRoleId">Användarroll:</label>
                        <select id="userRoleSelect" class="select-control" style="width: 240px;" asp-for="UserRoleId" asp-items="Model.UserRoleListItems"></select>
                        <span asp-validation-for="UserRoleId" class="text-danger"></span>
                    </div>  
                    
                    <div class="mb-3">
                        <label asp-for="PreventAccess">Stäng av användaren från LexiElectronics webbshop:</label>

                        <div class="form-check">
                            <input class="form-check-input" asp-for="PreventAccess" type="radio" value="true" id="Access_True" />
                            <label class="form-check-label" for="Access_True">Ja</label>
                        </div>

                        <div class="form-check">
                            <input class="form-check-input" asp-for="PreventAccess" type="radio" value="false" id="Access_False" />
                            <label class="form-check-label" for="Access_False">Nej</label>
                        </div>

                        <span asp-validation-for="PreventAccess" class="text-danger"></span>
                    </div>
                     
           
                    <div class="mb-3">
                        <div style="float: left; width: 40%; margin-right: 20px;">
                            <label asp-for="Firstname">Förnamn: *</label>
                            <input asp-for="Firstname" class="form-control" aria-required="true" placeholder="Ditt förnamn" />
                            <span asp-validation-for="Firstname" class="text-danger"></span>
                        </div>
                        <div style="float: left; width:55%;">
                            <label asp-for="Lastname">Efternamn: *</label>
                            <input asp-for="Lastname" class="form-control" aria-required="true" placeholder="Ditt efternamn" />
                            <span asp-validation-for="Lastname" class="text-danger"></span>
                        </div>
                    </div>
                    <div style="width: 100%; height: 20px; clear: both;"></div>
                    <div class="mb-3">
                        <label asp-for="UserName">Användarnamn (Epost) *</label>
                        <input asp-for="UserName" class="form-control" placeholder="Please choose your username." disabled/>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email">Epost: *</label>
                        <input asp-for="Email" class="form-control" placeholder="Användarens epost." />
                    </div>

                    <div class="mb-3">
                        <label asp-for="PhoneNumber">Telefonnr:</label>
                        <input asp-for="PhoneNumber" class="form-control" placeholder="Ange ditt telefonnr." />
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>

                    <div><strong>Fakturaadress:</strong></div>
                    <div class="mb-3">
                        <label asp-for="InvoiceName">Namn: *</label>
                        <input asp-for="InvoiceName" class="form-control" aria-required="true" placeholder="Ditt namn" />
                        <span asp-validation-for="InvoiceName" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="InvoiceStreetAddress">Gatuadress: *</label>
                        <input asp-for="InvoiceStreetAddress" class="form-control" aria-required="true" placeholder="Din gatuadress" />
                        <span asp-validation-for="InvoiceStreetAddress" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <div style="float: left; width: 29%; margin-right: 20px;">
                            <label asp-for="InvoiceZipcode">Postnr: *</label>
                            <input asp-for="InvoiceZipcode" class="form-control" aria-required="true" placeholder="Ditt postnr" />
                            <span asp-validation-for="InvoiceZipcode" class="text-danger"></span>
                        </div>
                        <div style="float: left; width:66%;">
                            <label asp-for="InvoiceCity">Ort: *</label>
                            <input asp-for="InvoiceCity" class="form-control" aria-required="true" placeholder="Din ort" />
                            <span asp-validation-for="InvoiceCity" class="text-danger"></span>
                        </div>
                    </div>

                    <div style="width: 100%; height: 20px; clear: both;"></div>

                    <div style="margin-top: 25px;"><strong>Leveransadress:</strong></div>
                    <div class="mb-3">
                        <label asp-for="DeliveryName">Namn</label>
                        <input asp-for="DeliveryName" class="form-control" aria-required="false" placeholder="Ditt namn" />
                        <span asp-validation-for="DeliveryName" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="DeliveryStreetAddress">Gatuadress</label>
                        <input asp-for="DeliveryStreetAddress" class="form-control" aria-required="false" placeholder="Din gatuadress" />
                        <span asp-validation-for="DeliveryStreetAddress" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <div style="float: left; width: 29%; margin-right: 20px;">
                            <label asp-for="DeliveryZipcode">Postnr</label>
                            <input asp-for="DeliveryZipcode" class="form-control" aria-required="false" placeholder="Ditt postnr" />
                            <span asp-validation-for="DeliveryZipcode" class="text-danger"></span>
                        </div>
                        <div style="float: left; width: 66%;">
                            <label asp-for="DeliveryCity">Ort</label>
                            <input asp-for="DeliveryCity" class="form-control" aria-required="false" placeholder="Din ort" />
                            <span asp-validation-for="DeliveryCity" class="text-danger"></span>
                        </div>
                    </div>
                    <div style="width: 100%; height: 20px; clear: both;"></div>
                </div>

                <button id="update-profile-button" type="submit" class="w-100 btn btn-lg btn-primary">Spara</button>
            </form>
        </div>
    
        @section Scripts {
            <partial name="_ValidationScriptsPartial" />
        }
    }
</div>
